# ============================================================
# PR Task Manager — Environment Variables
# ============================================================
# cp .env.example .env  → isi nilainya
# ⚠️  Jangan commit file .env ke repository!
# ============================================================

# ------------------------------------------------------------
# Google OAuth 2.0 — Web Application (WAJIB)
# ------------------------------------------------------------
# Setup di Google Cloud Console:
# 1. APIs & Services → Credentials → Create Credentials
#    → OAuth 2.0 Client ID → Web Application
# 2. Authorized JavaScript origins:
#      http://localhost:3000
#      https://domain-kamu.com
# 3. Authorized redirect URIs:
#      http://localhost:3000/oauth/callback
#      https://domain-kamu.com/oauth/callback
#
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Secret key untuk encrypt/decrypt data user (WAJIB)
# ------------------------------------------------------------
# Generate random string panjang, contoh:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
VITE_SECRET_KEY=ganti_dengan_random_string_panjang

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=3000
APP_URL=https://domain-kamu.com
