# ============================================================
# PR Task Manager — Environment Variables
# ============================================================
# Salin file ini ke .env lalu isi nilainya:
#   cp .env.example .env
#
# ⚠️  Jangan pernah commit file .env ke repository!
# ============================================================

# ------------------------------------------------------------
# Google OAuth 2.0 Client ID (WAJIB)
# ------------------------------------------------------------
# Cara mendapatkan:
# 1. Buka https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create Credentials
#    → OAuth 2.0 Client ID → Web Application
# 3. Authorized JavaScript origins:
#      http://localhost:5173
#      https://domain-kamu.com
# 4. Authorized redirect URIs:
#      http://localhost:5173/oauth/callback
#      https://domain-kamu.com/oauth/callback
# 5. Copy Client ID di bawah ini
#
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ------------------------------------------------------------
# (Opsional) Override port development
# ------------------------------------------------------------
# Default port Vite adalah 5173.
# Uncomment dan ganti jika ingin menggunakan port lain.
#
# VITE_PORT=5173

# ------------------------------------------------------------
# (Opsional) Base URL untuk OAuth redirect
# ------------------------------------------------------------
# Otomatis menggunakan window.location.origin jika tidak diisi.
# Isi ini jika app diakses melalui reverse proxy / Cloudflare Tunnel
# dengan domain berbeda dari localhost.
#
# VITE_APP_URL=https://tasks.domain-kamu.com
